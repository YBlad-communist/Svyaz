# ⚠️ ВАЖНО: Скопируйте этот файл в .env и замените SECRET_KEY и пароли!
# Генерация SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"

# SECRET_KEY — обязательный. НЕ ИСПОЛЬЗУЙТЕ ЭТОТ КЛЮЧ В ПРОДАКШЕНЕ!
SECRET_KEY=change-this-to-a-real-secret-key-in-production

# PostgreSQL (если не указана DATABASE_URL)
# При Docker-деплое пароль читается из Docker Secret /run/secrets/db_password
POSTGRES_PASSWORD=change-this-to-a-strong-password

# Либо полный URI (приоритетнее)
# DATABASE_URL=postgresql+psycopg2://svyaz:password@db:5432/svyaz

# Redis (опционально, для rate limiting)
REDIS_HOST=redis
REDIS_PORT=6379

# Flask
FLASK_ENV=production
FLASK_DEBUG=0

# Nginx домен — замените на ваш домен
# DOMAIN=example.com

# TESTING — set to 1 for tests (uses SQLite in-memory)
# TESTING=0
